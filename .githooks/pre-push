#!/usr/bin/env sh
# Local pre-push check: fast unit tests only (no Docker/Testcontainers).
# Enable with: git config core.hooksPath .githooks
# Run integration tests separately with `mvn verify` (requires Docker).
set -e

repo_root="$(git rev-parse --show-toplevel)"

echo "==> Running backend unit tests (mvn test)"
(cd "$repo_root" && mvn -q test)

echo "==> Running Angular lint (ng lint)"
(cd "$repo_root/angular-ui" && npm run lint)

echo "==> Running Angular unit tests (ng test)"
if [ -z "$CHROME_BIN" ]; then
  edge="/c/Program Files (x86)/Microsoft/Edge/Application/msedge.exe"
  if [ -z "$(command -v google-chrome 2>/dev/null)$(command -v chromium 2>/dev/null)" ] && [ -f "$edge" ]; then
    export CHROME_BIN="$edge"
  fi
fi
(cd "$repo_root/angular-ui" && npm test -- --watch=false --browsers=ChromeHeadless)

echo "==> Pre-push checks passed"
