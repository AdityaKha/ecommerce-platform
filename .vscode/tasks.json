{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Discovery Server",
      "type": "shell",
      "command": "mvn \"spring-boot:run\"",
      "options": {
        "cwd": "${workspaceFolder}/discovery-server"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "close": true
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting DiscoveryServerApplication",
          "endsPattern": "Tomcat started on port"
        }
      }
    },
