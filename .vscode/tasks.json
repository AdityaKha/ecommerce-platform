    {
      "label": "Start All Services",
      "dependsOn": [
        "Product Service",
        "Order Service",
        "Inventory Service",
        "Notification Service",
        "Angular UI"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Stop All Services",
      "type": "shell",
      "command": "Get-Process java -ErrorAction SilentlyContinue | Stop-Process -Force; Get-CimInstance Win32_Process -Filter 'name=''node.exe''' | Where-Object { $_.CommandLine -like '*@angular*' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue }; Write-Host 'All services stopped.'",
      "presentation": {
        "panel": "shared",
        "reveal": "always",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Restart All Services",
      "dependsOn": [
        "Stop All Services",
        "Start All Services"̥̥
      ],
      "dependsOrder": "sequence",
