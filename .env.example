# Copy to .env (gitignored) before running `docker compose up` or any service
# natively:
#
#   cp .env.example .env        # then change every value
#
# docker-compose reads .env automatically; for native `mvn spring-boot:run`
# export the variables in your shell instead. None of these have checked-in
# defaults — services fail fast at startup if they are missing.
#
# Generate strong random values, e.g.:  openssl rand -base64 48

# JWT signing secret shared by api-gateway and auth-service (min 32 bytes).
JWT_SECRET=

# Shared secret proving a request came through the gateway (X-Internal-Token);
# required by auth/product/order/inventory services.
INTERNAL_TOKEN=

# PostgreSQL password, used both to initialize the compose Postgres container
# and by the four DB-backed services. (Username defaults to `postgres`;
# override with DB_USERNAME if yours differs.)
DB_PASSWORD=
